{
  "builds": [
    {
      "src": "back-end/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "javascript/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(api/.*)",
      "dest": "/back-end/app.py"
    },
    {
      "src": "/(register|login|update-username|categories|expenses|export-ledger|generate-backup-bat|backup-expenses|analytics|seed-data)",
      "dest": "/back-end/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
